#--- Fonts ---
font-family = "FiraMono Nerd Font Mono"
font-size = 11.0

# 'cursor-style' values are "bar", "block", "underline", "block_hollow"
cursor-style = "bar"

theme = iTerm2 Solarized Dark

# background-opacity = 0.9

selection-foreground = "#000000"
selection-background = "#fffacd"

#This syntax requires recent version of ghostty (ie 1.1.14)
keybind = f11=toggle_fullscreen
